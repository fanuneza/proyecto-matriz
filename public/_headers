# Next.js static assets: content-hashed filenames → immutable forever
/_next/static/*
  Cache-Control: public, max-age=31536000, immutable

# HTML pages: always revalidate (CDN may serve stale)
/*
  Cache-Control: public, max-age=0, must-revalidate

# OG image: immutable (only changes on deliberate redeploy)
/og-image.jpg
  Cache-Control: public, max-age=31536000, immutable

# Crawl files
/robots.txt
  Cache-Control: public, max-age=86400
/sitemap.xml
  Cache-Control: public, max-age=86400
